generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  password     String
  name         String?
  balance      Float         @default(25000)
  trades       Trade[]
  chatMessages ChatMessage[]
  dailyPlans   DailyPlan[]
  createdAt    DateTime      @default(now())
}

model Trade {
  id          String       @id @default(cuid())
  date        DateTime
  asset       String
  direction   String
  strategy    String
  entry       Float
  exit        Float?
  sl          Float
  tp          Float
  lots        Float
  result      Float
  emotion     String?
  setup       String?
  tags        String?
  rating      Int?
  notes       String?
  duration    Int?
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  screenshots  Screenshot[]
  chatMessages ChatMessage[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Screenshot {
  id      String @id @default(cuid())
  url     String
  tradeId String
  trade   Trade  @relation(fields: [tradeId], references: [id], onDelete: Cascade)
}

model DailyPlan {
  id        String   @id @default(cuid())
  date      DateTime
  bias      String?
  notes     String?
  pairs     String?
  keyLevels String?
  review    String?
  grade     String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}

model ChatRoom {
  id          String        @id @default(cuid())
  name        String        @unique
  description String?
  icon        String?
  order       Int           @default(0)
  messages    ChatMessage[]
  createdAt   DateTime      @default(now())
}

model ChatMessage {
  id        String   @id @default(cuid())
  content   String
  imageUrl  String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  roomId    String
  room      ChatRoom @relation(fields: [roomId], references: [id])
  tradeId   String?
  trade     Trade?   @relation(fields: [tradeId], references: [id])
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
}
