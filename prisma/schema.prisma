generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  password     String
  name         String?
  role         String        @default("USER")
  balance      Float         @default(25000)
  trades       Trade[]
  chatMessages ChatMessage[]
  dailyPlans   DailyPlan[]
  strategies   Strategy[]
  tags         Tag[]
  monthlyGoals MonthlyGoal[]
  tradingRules TradingRule[]
  reactions    Reaction[]
  resetToken       String?
  resetTokenExpiry DateTime?
  vipPosts     VipPost[]
  createdAt    DateTime      @default(now())
}

model Trade {
  id           String       @id @default(cuid())
  date         DateTime
  asset        String
  direction    String
  strategy     String
  entry        Float
  exit         Float?
  sl           Float
  tp           Float
  lots         Float
  result       Float
  emotion      String?
  setup        String?
  tags         String?
  rating       Int?
  notes        String?
  duration     Int?
  commission   Float?       @default(0)
  swap         Float?       @default(0)
  maePrice     Float?
  mfePrice     Float?
  strategyId   String?
  strategyRel  Strategy?    @relation(fields: [strategyId], references: [id])
  userId       String
  user         User         @relation(fields: [userId], references: [id])
  screenshots  Screenshot[]
  tradeTags    TradeTag[]
  chatMessages ChatMessage[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Screenshot {
  id      String @id @default(cuid())
  url     String
  tradeId String
  trade   Trade  @relation(fields: [tradeId], references: [id], onDelete: Cascade)
}

model Strategy {
  id          String   @id @default(cuid())
  name        String
  color       String   @default("#0ea5e9")
  description String?
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  trades      Trade[]
  createdAt   DateTime @default(now())

  @@unique([userId, name])
}

model Tag {
  id     String     @id @default(cuid())
  name   String
  color  String     @default("#6b7280")
  userId String
  user   User       @relation(fields: [userId], references: [id])
  trades TradeTag[]

  @@unique([userId, name])
}

model TradeTag {
  tradeId String
  trade   Trade  @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  tagId   String
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([tradeId, tagId])
}

model MonthlyGoal {
  id            String @id @default(cuid())
  month         Int
  year          Int
  targetPnl     Float?
  targetTrades  Int?
  targetWinRate Float?
  userId        String
  user          User   @relation(fields: [userId], references: [id])

  @@unique([userId, month, year])
}

model TradingRule {
  id     String @id @default(cuid())
  text   String
  order  Int    @default(0)
  userId String
  user   User   @relation(fields: [userId], references: [id])
}

model DailyPlan {
  id          String   @id @default(cuid())
  date        DateTime
  bias        String?
  notes       String?
  pairs       String?
  keyLevels   String?
  review      String?
  grade       String?
  screenshots String[] @default([])
  shared      Boolean  @default(false)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, date])
}

model ChatRoom {
  id          String        @id @default(cuid())
  name        String        @unique
  description String?
  icon        String?
  order       Int           @default(0)
  messages    ChatMessage[]
  createdAt   DateTime      @default(now())
}

model ChatMessage {
  id        String     @id @default(cuid())
  content   String
  imageUrl  String?
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  roomId    String
  room      ChatRoom   @relation(fields: [roomId], references: [id])
  tradeId   String?
  trade     Trade?     @relation(fields: [tradeId], references: [id])
  isPinned  Boolean    @default(false)
  reactions Reaction[]
  createdAt DateTime   @default(now())
}

model Reaction {
  id        String      @id @default(cuid())
  emoji     String
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  messageId String
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([userId, messageId, emoji])
}

model VipPost {
  id          String   @id @default(cuid())
  title       String
  type        String   // "indicator" | "macro" | "options" | "futures"
  content     String   @db.Text
  scriptCode  String?  @db.Text  // Pine Script or indicator code
  imageUrl    String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
}
